# MarketSYS Backend - ejemplo de configuracion
# Copia este archivo como .env en el equipo real y reemplaza los valores.

PORT=5000
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_mysql
DB_PASS=contrasena_mysql
DB_NAME=pos

JWT_SECRET=cambia_esta_clave_por_una_segura

CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Usado por tareas internas si se requiere apuntar a la API local.
API_URL=http://localhost:5000
